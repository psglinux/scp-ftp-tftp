# Build output
build/
build-*/

# Release packages — only latest/ and <tag>/ dirs exist at runtime;
# none of their binary contents belong in git.
release/latest/
release/*/
!release/.gitkeep

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db

# SSH test keys (private key must not be committed)
tests/docker/ssh_test_key

# Compiled objects
*.o
*.obj
*.a
*.lib
*.so
*.dylib
